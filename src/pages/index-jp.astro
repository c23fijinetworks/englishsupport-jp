---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Stats from '~/components/widgets/Stats.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';

const metadata = { title: 'English Support | 日本の価値を世界へ繋ぐ、高付加価値マーケティング' };
---
<Layout metadata={metadata}>
  
  <Hero2
    tagline="英語デジタルマーケティング"
    title='貴社のビジネスを、<br/><span class="text-accent dark:text-white">地域と世界の顧客へ繋ぐ。</span>'
    subtitle="ブランドの成長を加速させるプレミアム・マーケティング拠点とレピュテーション戦略を構築。最短24〜48時間で、集客の「顔」となるデジタルプレゼンスをスピーディーに提供いたします。"
    actions={[
      { variant: 'primary', text: 'サービス一覧', href: '#services' },
      { text: '特別案件のご相談', href: '/contact-jp', class: '!bg-orange-600 !text-white !border-none hover:!bg-orange-700' },
    ]}
    image={{ src: '/images/hanei-media/033.webp', alt: '日本の街並み' }}
    classes={{ inner: 'pb-4 md:pb-6' }}
  />

  <div class="text-center px-4 mb-4 mt-12 md:mt-20">
    <h2 class="text-2xl md:text-4xl font-black text-slate-950 uppercase tracking-tighter mb-2">圧倒的な成果を生むプレミアム英語マーケティング</h2>
    <p class="text-lg md:text-xl text-slate-600 font-bold uppercase tracking-widest">国内外の関心を、確実な予約へと変換する</p>
  </div>
  <Stats
    classes={{ container: 'pt-0 md:pt-0 pb-12' }}
    stats={[ 
      { title: 'ブランド構築', amount: '100%' }, 
      { title: '英語対応', amount: 'Fluent' }, 
      { title: '最短公開', amount: '24時間' }, 
      { title: '月額費用', amount: '¥0' }
    ]} 
  />

  <Content 
    id="services"
    tagline="サービス：インバウンド・ウェルカム・ブランディング" 
    title="新規顧客が貴社を見つけ、選びやすくなる仕組み。" 
    subtitle="店舗のルールやメニューを明確に説明する、成約率の高いデジタルブランドガイドを構築します。地域住民も旅行者も安心して貴社の扉を叩けるよう、不透明さを排除することが集客の第一歩です。" 
    callToAction={{ text: 'インバウンド・ウェルカムの詳細', href: '/one-page-welcome-jp' }} 
    image={{ src: '/images/demos/shika-an-nara-luxury-heritage-guesthouse.webp', alt: 'ウェルカム・デモ' }} 
  />

  <Content 
    isReversed={true} 
    tagline="サービス：レピュテーション・マーケティング" 
    title="自動更新されるレビュー・ウォールで、即座に信頼を構築。" 
    subtitle="最高の顧客体験をデジタル拠点上に直接表示し、品質を証明します。Googleでの星5つの評価を促進する自動マーケティング資産を導入し、新規客の来店を強力に後押しします。" 
    callToAction={{ text: 'レビューマーケティングの詳細', href: '/review-engine-jp' }} 
    image={{ src: '/images/review_engine/testimonial-6.webp', alt: 'レビュー・デモ' }} 
  />

  <Content 
    isReversed={false} 
    tagline="サービス：英語専用デジタル別館（Hanare）" 
    title="既存サイトはそのまま。プロ仕様の英語セクションを追加。" 
    subtitle="既存資産の安全を守りつつ、海外顧客専用の領域を構築。グローバルなターゲットを惹きつける最速の方法です。戦略的なレイアウトから翻訳まで、すべてお任せください。" 
    callToAction={{ text: '英語専用別館の詳細', href: '/english-hanare-jp' }} 
    image={{ src: '/images/demos/capsule-hotel.webp', alt: '別館デモ' }} 
  />

  <Content 
    isReversed={true} 
    tagline="サービス：ブランドの刷新と新規公開" 
    title="最新のデザインで、貴社のプレゼンスを再定義。" 
    subtitle="既存のプレゼンスを刷新、あるいはゼロから旗艦店を構築。スマートフォンに最適化されたモダンなデジタルプレゼンスで競合他社に圧倒的な差をつけ、成約を勝ち取る目的地を提供します。" 
    callToAction={{ text: '制作オプションを見る', href: '/grand-opening-jp' }} 
    image={{ src: '/images/hanei-media/021.webp', alt: 'リブート・デモ' }} 
  />

  <Content 
    isReversed={false} 
    tagline="地域貢献活動" 
    title="慈善団体・NPOへのクリエイティブ支援。" 
    subtitle="日本国内のNPO法人や地域サービスに対し、高品質なブランド支援を無償で提供しています。社会に貢献する活動をデジタルの力で支えることが、私たちのミッションです。" 
    callToAction={{ text: '私たちのミッション', href: '/community-mission-jp' }} 
    image={{ src: '/images/hanei-media/031.webp', alt: 'NPO支援' }} 
  />

  <FAQs 
    title="よくあるご質問" 
    classes={{ container: 'pt-8 md:pt-12' }} 
    items={[
      { title: 'マーケティングの知識は必要ですか？', description: 'いいえ。弊社のデジタル拠点は、導入した瞬間からブランドにインパクトを与えるよう設計されています。戦略的なストーリーテリングと視認性の向上をすべて代行するため、専門知識は不要です。' }, 
      { title: '公開までどのくらいかかりますか？', description: 'パッケージプランは24時間以内、フルブランドの刷新でも最短48時間以内での納品を標準としております。' }, 
      { title: '月額費用は発生しますか？', description: 'いいえ。主要なサービスの多くは一括投資（買い切り）モデルです。継続的なサブスクリプション費用なしで、デジタルの拠点を永久に所有いただけます。' }, 
      { title: '海外の顧客をどう惹きつけるのですか？', description: '国際的なターゲットに響く専用の英語デジタル資産を展開します。世界中のゲストが検索する場所に貴社を正しく位置づけることで、インバウンドの視認性を最大化します。' }
    ]} 
    callToAction={{ variant: 'primary', text: 'すべてのFAQを見る', href: '/faq-jp' }} 
  />
</Layout>
