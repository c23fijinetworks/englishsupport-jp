---
import Hero2 from '~/components/widgets/Hero2.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';
import Pricing from '~/components/widgets/Pricing.astro';

const metadata = { 
  title: 'Reputation Review Marketing | Automate 5-Star Social Proof | English Support',
  description: 'Turn happy customers into your best marketing assets. Our managed QR-driven marketing asset makes it effortless for guests to leave 5-star Google reviews.'
};

const pricingData = { 
  title: 'Reputation Review Marketing Package', 
  price: '¥19,800', 
  subTitle: 'Get It Now',
  badge: 'One-time Marketing Investment <br/> Lifetime Growth',
  items: [
    { description: 'Branded Review Portal Design' }, 
    { description: 'Direct Google Maps Integration' }, 
    { description: 'Automated Live Review Display' }, 
    { description: 'High-Speed Edge Delivery' },
    { description: 'Launch ready in 24 hours' }
  ]
};
---
<Layout metadata={metadata}>
  <Hero2 
    tagline="Reputation on Autopilot" 
    title='Turn a "Thank You" <br/><span class="text-accent">into a 5-Star Review.</span>' 
    subtitle='Stop letting happy customers leave without saying a word. We make it effortless for them to praise your business on Google using a strategic marketing flow that we fully manage for you.' 
    actions={[{ variant: 'primary', text: 'Get Started', href: '#pricing' }]} 
    image={{ src: '/images/review_engine/testimonial-1.webp', alt: 'Review' }} 
  />
  
  <Content 
    isReversed={false} 
    title="01. Branded Review Portal" 
    subtitle="A premium digital red carpet for your guests. Clean, inviting, and tailored to your brand. Our portal is fully managed on our global network, ensuring your review page loads instantly for every customer regardless of their data connection." 
    items={[{ title: 'Visual Trust', description: 'No messy forms, just simple interaction.', icon: 'tabler:palette' }]} 
    image={{ src: '/images/review_engine/testimonial-2.webp', alt: 'Portal' }} 
  />
  
  <Content 
    isReversed={true} 
    title="02. The Live Wall of Fame" 
    subtitle="Display your best reviews automatically on your own marketing hub to instantly prove your excellence. This live social proof builds immediate confidence with new visitors who are looking for a high-quality, trusted establishment in your neighborhood." 
    items={[{ title: 'Social Proof', description: 'Verified satisfaction shown in real-time.', icon: 'tabler:stars' }]} 
    image={{ src: '/images/review_engine/testimonial-3.webp', alt: 'Wall' }} 
  />
  
  <Content 
    isReversed={false} 
    title="03. Frictionless 3-Click Flow" 
    subtitle="We optimize the mobile journey so leaving a review takes less than 15 seconds—no apps required. By serving a streamlined QR code experience, we help you capture the customer's peak satisfaction while they are still physically present in your shop." 
    items={[{ title: 'Speed is King', description: 'Capture the glow before they leave the shop.', icon: 'tabler:pointer' }]} 
    image={{ src: '/images/review_engine/testimonial-4.webp', alt: 'Click' }} 
  />
  
  <Content 
    isReversed={true} 
    title="04. SEO Boost Engine" 
    subtitle="Continuous fresh reviews signal to Google that your brand is active and the #1 choice in your area. This automated marketing engine keeps your business at the top of local search results, ensuring you are the first name seen by residents and travelers alike." 
    items={[{ title: 'Rank Higher', description: 'Google rewards businesses with fresh activity.', icon: 'tabler:trending-up' }]} 
    image={{ src: '/images/review_engine/testimonial-5.webp', alt: 'SEO' }} 
  />

  <Pricing 
    id="pricing" 
    title="One Simple Price. Lifetime Growth." 
    subtitle="Automate your reputation today. No recurring monthly fees ever."
    prices={[pricingData]} 
  />
</Layout>
