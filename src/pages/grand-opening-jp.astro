---
import Hero2 from '~/components/widgets/Hero2.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';
import FeatureTable from '~/components/widgets/FeatureTable.astro';
import Pricing from '~/components/widgets/Pricing.astro';

const metadata = { title: 'グランドオープニング | エリート・ブランド・プレゼンスの構築 | English Support' };

const fullFeatureList = [{ title: '世界基準の高速配信' }, { title: '日英バイリンガル・ナビ' }, { title: 'Googleマップ連携' }, { title: 'モバイルファースト設計' }, { title: 'SSL暗号化通信' }, { title: '予約・問い合わせフロー' }, { title: 'ネイティブ英語コピー執筆' }, { title: 'SNSフィード連携' }, { title: '画像データの最適化' }, { title: '最新ブラウザ互換対応' }, { title: 'ダウンタイムなしの移行' }, { title: '修正回数無制限' }, { title: '1営業日でのスピード公開' }, { title: 'プロフェッショナル構造化データ' }, { title: '予約フォーム統合' }, { title: 'プライバシーポリシー対応' }, { title: '世界基準の英語ブランディング' }, { title: '60日間の視認性サポート' }];

const reformPrices = [
  { title: 'スターター・リフォーム', total: '¥70,000', price: '¥35,000', items: [{ description: 'ブランドをモダンなデザインへ刷新' }, { description: '既存のテキストと写真を移行' }, { description: 'スマホ表示に完全対応' }, { description: '超高速な表示速度' }, { description: '最短3日でのスピード公開' }] },
  { title: 'グロース・リフォーム', total: '¥130,000', price: '¥65,000', items: [{ description: '最大8ページのデザイン刷新' }, { description: 'プロのネイティブによる英語執筆' }, { description: 'Google検索での視認性向上' }, { description: 'Googleマップ＆レビュー連携' }, { description: '優先2営業日デリバリー' }] },
  { title: 'プレミアム・リフォーム', total: '¥250,000', price: '¥125,000', items: [{ description: '大規模なブランド拠点の刷新' }, { description: 'カスタム予約・問い合わせロジック' }, { description: 'テキスト・写真の無制限更新' }, { description: '専属戦略アドバイザーによるサポート' }, { description: '翌営業日の最優先公開' }] }
];

const newBuildPrices = [
  { title: 'スターター・ビルド', total: '¥90,000', price: '¥45,000', items: [{ description: '3ページのプロ仕様拠点を新規制作' }, { description: 'カスタムメイドの洗練された外観' }, { description: 'モバイルユーザーに完全最適化' }, { description: '高度なセキュリティのホスティング' }, { description: '最短3日でのスピード公開' }] },
  { title: 'グロース・ビルド', total: '¥180,000', price: '¥90,000', items: [{ description: '8ページの最高級ブランド旗艦サイト' }, { description: '予約・問い合わせ導線の統合' }, { description: '高度なGoogle検索対策設定' }, { description: 'Instagram投稿のリアルタイム同期' }, { description: '優先2営業日デリバリー' }] },
  { title: 'プレミアム・ビルド', total: '¥380,000', price: '¥190,000', items: [{ description: 'ページ無制限の完全カスタム公開' }, { description: '業界特化のオーダーメイド機能' }, { description: 'Googleでの最大級の権威性構築' }, { description: '生涯優先テクニカルケア' }, { description: '翌営業日の最優先公開' }] }
];

const jpTexts = { 
  labelBiz: "1. 店名・貴社名", 
  phBiz: "名称を入力", 
  labelWeb: "2. 現在のサイト (任意)", 
  phWeb: "https://...", 
  labelEmail: "連絡先メールアドレス", 
  phEmail: "example@mail.com", 
  submit: "決済して制作を開始する",
  totalInv: "総投資額"
};
---
<Layout metadata={metadata}>
  <Hero2 tagline="トータル・ブランド・トランスフォーメーション" title='貴社のプレゼンスは、<br/><span class="text-accent">集客に貢献していますか？</span>' subtitle="時代遅れのプレゼンスは、顧客を遠ざけます。私たちは貴社の「デジタルの玄関口」を、わずか1営業日でプロフェッショナルな姿へと変貌させます。" actions={[{ variant: 'primary', text: '「ブランド・リフォーム」を見る', href: '#reform' }, { variant: 'secondary', text: '「グランド・ニュー」を見る', href: '#new', class: '!bg-green-600 !text-white hover:!bg-green-700' }]} image={{ src: '/images/demos/private-kyoto-temple-expeditions.webp', alt: 'プレミアム・東京' }} />
  
  <div id="reform" class="scroll-mt-20">
    <Content tagline="Option 1: ブランド・リフォーム" title="01. モダンな美学への刷新" subtitle="既存のコンテンツを尊重しつつ、デザインの魂を国際的なラグジュアリー基準へとアップデートします。" items={[{ title: '洗練された外観', description: 'ハイエンドな認知を獲得するための設計。', icon: 'tabler:palette' }]} image={{ src: '/images/demos/mizu-no-kokoro-luxury-sento-wellness-osaka.webp', alt: 'デザイン' }} classes={{ container: 'pb-0 md:pb-0' }} />
    <Content isReversed={true} isAfterContent={true} title="伝統を継承し、影響力を高める" subtitle="これまでの歩みを尊重します。リフォームプロセスでは、既存のテキストや歴史を継承しつつ、それを世界水準のインターフェースで包み込みます。" image={{ src: '/images/hanei-media/032.webp' }} classes={{ container: 'py-8 md:py-12' }} />
    <Content isReversed={false} isAfterContent={true} title="ブランド視認性の向上" subtitle="リフォームされたプレゼンスを高速ネットワークへ移行。あらゆる通信環境において、1秒未満の表示速度を実現します。" image={{ src: '/images/demos/kura-tokyo-premium-luggage-concierge-secure-storage.webp' }} classes={{ container: 'py-8 md:py-12' }} />
    
    <Pricing title="ブランド・リフォーム投資額" subtitle="既存の拠点を最新のラグジュアリー基準へ。" prices={reformPrices} hasUrlField={true} texts={jpTexts} />
  </div>

  <hr class="border-t dark:border-slate-800 my-12" />

  <div id="new" class="scroll-mt-20">
    <Content isReversed={true} tagline="Option 2: グランド・ニュー" title="02. ブランド・ブループリント" subtitle="初日から最大のコンバージョンを生むように設計された、貴社のブランド・エコシステムをゼロから構築します。" items={[{ title: '完全新規ローンチ', description: '貴社の特定のニッチ市場に合わせてカスタム設計。', icon: 'tabler:rocket' }]} image={{ src: '/images/hanei-media/003.webp', alt: '新規構築' }} classes={{ container: 'pb-0 md:pb-0' }} />
    <Content isReversed={false} isAfterContent={true} title="成約率を追求した設計" subtitle="訪問者を確実に顧客へと変えるため、独自のコンバージョン・ロジックに基づいたナビゲーションと予約機能を設計します。" image={{ src: '/images/hanei-media/029.webp' }} classes={{ container: 'py-8 md:py-12' }} />
    <Content isReversed={true} isAfterContent={true} title="クリエイティブ・ローンチ・ロジック" subtitle="貴社の新たな旗艦店は、揺るぎない安定性と自動化されたSEO戦略を提供する高パフォーマンスな環境に構築されます。" image={{ src: '/images/demos/kissa-co-osaka.webp' }} classes={{ container: 'py-8 md:py-12' }} />
    
    <Pricing title="グランド・ニュー投資額" subtitle="ゼロから最強の旗艦拠点を構築します。" prices={newBuildPrices} texts={jpTexts} />
  </div>

  <FeatureTable title="世界を迎え入れる：グローバル英語マーケティング機能" subtitle="すべてのプロフェッショナル・プロジェクトに含まれるエリート機能の一覧です。" items={fullFeatureList} footerText="最短1営業日で納品" />
</Layout>
