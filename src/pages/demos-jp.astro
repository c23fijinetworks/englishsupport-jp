---
import Hero2 from '~/components/widgets/Hero2.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = { 
  title: '制作実績デモ | 高コンバージョン・マーケティング拠点 | English Support',
  description: '日本の各業界向けに構築された、高コンバージョンなブティック・マーケティングデモのポートフォリオをご覧いただけます。'
};

const demos = [
  { title: "ZenPod Tokyo", sub: "日本の美意識と高い成約率を両立させた、ラグジュアリーなカプセルホテル・マーケティングフロー。", link: "/demos/capsule-hotel", img: "/images/demos/capsule-hotel.webp" },
  { title: "麻布プレミアムメディカル", sub: "外国人居住者向けの洗練された医療施設。ドクター主導のブランド・ポジショニングを体験してください。", link: "/demos/azabu-medical", img: "/images/demos/azabu-medical.webp" },
  { title: "GINZA KAIZEN", sub: "銀座の高級ヘアサロン。完全英語対応のコンシェルジュ機能をブランドとして統合。", link: "/demos/ginza-kaizen", img: "/images/demos/ginza-kaizen.webp" },
  { title: "Tokyo Locker & Storage", sub: "高度な視認性とサービス設計を組み合わせた、プレミアムなホスピタリティ・ブランディング。", link: "/demos/tokyo-locker-storage-premium-luggage-solutions", img: "/images/demos/tokyo-locker-storage-premium-luggage-solutions.webp" },
  { title: "Kagari Izakaya & Grill", sub: "季節のおまかせ予約ストーリーを備えた、新宿の高級ガストロノミー目的地。", link: "/demos/kagari-izakaya-grill-shinjuku-tokyo-gastronomy", img: "/images/demos/kagari-izakaya-grill-shinjuku-tokyo-gastronomy.webp" },
  { title: "Shika-An Nara", sub: "静寂と伝統的な贅沢に焦点を当てた、歴史的なゲストハウスのブランディング体験。", link: "/demos/shika-an-nara-luxury-heritage-guesthouse", img: "/images/demos/shika-an-nara-luxury-heritage-guesthouse.webp" },
  { title: "Tokyo Unseen", sub: "東京の隠れた名店を巡る、富裕層向けの食の探検ツアー・ブランドデザイン。", link: "/demos/osaka-unseen-luxury-culinary-expeditions", img: "/images/demos/osaka-unseen-luxury-culinary-expeditions.webp" },
  { title: "Takumi Precision", sub: "日本の製造業の卓越した技術を世界へ発信する、高付加価値ブランド戦略と海外マーケティング。", link: "/demos/takumi-precision-tokyo-engineering-the-future", img: "/images/demos/takumi-precision-tokyo-engineering-the-future.webp" },
  { title: "Omotesando Dental", sub: "外国人居住者や観光客をターゲットとした、自由診療メインの歯科クリニックの権威性構築。", link: "/demos/omotesando-dental", img: "/images/demos/omotesando-dental.webp" },
  { title: "KyoEthereal", sub: "京都の寺院でのプライベートな瞑想体験や、精神的な旅のブランド・プランニング。", link: "/demos/private-kyoto-temple-expeditions", img: "/images/demos/private-kyoto-temple-expeditions.webp" },
  { title: "Mizu no Kokoro", sub: "東京のハイエンド市場をターゲットとした、モダンなウェルネス施設のブランドデザイン。", link: "/demos/mizu-no-kokoro-luxury-sento-wellness-osaka", img: "/images/demos/mizu-no-kokoro-luxury-sento-wellness-osaka.webp" },
  { title: "Kura Tokyo", sub: "プレミアム・コンシェルジュ・ブランディングと、貴重品のための高品位なストーリーテリング。", link: "/demos/kura-tokyo-premium-luggage-concierge-secure-storage", img: "/images/demos/kura-tokyo-premium-luggage-concierge-secure-storage.webp" },
  { title: "Kissa & Co.", sub: "職人による自家焙煎とハンドドリップの儀式を伝える、ブティック・ロースタリーのブランド体験。", link: "/demos/kissa-co-osaka", img: "/images/demos/kissa-co-osaka.webp" },
  { title: "Zen Relocations", sub: "国際的なコミュニティ向けの、日本の細やかなおもてなしを体現した引越しブランディング・サービス。", link: "/demos/zen-relocations-japan-relocations", img: "/images/demos/zen-relocations-japan-relocations.webp" }
];
---
<Layout metadata={metadata}>
  <Hero2 
    tagline="Haneiのベンチマーク" 
    title='ブティック・パフォーマンス。<br/><span class="text-accent">比類なき精度。</span>' 
    subtitle="厳選されたデジタル・デモンストレーションのギャラリーをご体感ください。すべてのアセットは、高コンバージョンを追求したクリエイティブ・ロジックの結晶。日本が誇る卓越したクオリティを、世界に通用する圧倒的な権威へと昇華させるべく、細部まで緻密に設計されています。"
    image={{ src: '/images/demos/omotesando-dental.webp', alt: 'Hanei Showcase' }}
  />

  <div class="space-y-4">
    {demos.map((demo, index) => (
      <Content 
        isReversed={index % 2 !== 0}
        title={`制作デモ: ${demo.title}`}
        subtitle={demo.sub}
        callToAction={{ variant: 'primary', text: 'デモを起動', href: demo.link, target: '_blank' }}
        image={{ src: demo.img, alt: demo.title }}
        classes={{ container: 'py-12 md:py-20' }}
      />
    ))}
  </div>
</Layout>
