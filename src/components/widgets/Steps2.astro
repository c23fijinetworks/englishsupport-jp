---
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  callToAction = {},
  items = [],
  image: imageProp,
} = Astro.props;

const imageSlot = await Astro.slots.render('image');
const image = imageProp || imageSlot;
---

<section class="bg-primary-50 dark:bg-slate-800 py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Standard flex-col ensures text (top div) appears before image on mobile -->
    <div class="flex flex-col md:flex-row gap-16 items-center">
      
      <!-- Text Container (Lead on Mobile) -->
      <div class="flex flex-col justify-center md:basis-1/2 w-full">
        {title && <h2 class="text-4xl md:text-5xl font-bold font-heading mb-6 tracking-tighter" set:html={title}></h2>}
        {subtitle && <p class="text-muted dark:text-slate-400 mb-10 text-xl leading-relaxed" set:html={subtitle}></p>}
        
        {items && items.length > 0 && (
          <div class="grid gap-6 mb-10">
            {items.map(({ title: ititle, description, icon }) => (
              <div class={ititle ? "flex items-start" : "flex items-center -my-3"}>
                <div class="flex-shrink-0 flex justify-center w-12">
                  <div class={ititle 
                    ? "flex items-center justify-center h-12 w-12 rounded-full bg-primary text-white shadow-xl" 
                    : "flex items-center justify-center h-8 w-12 text-slate-400 dark:text-slate-500"
                  }>
                    <Icon name={icon || 'tabler:check'} class={ititle ? "w-6 h-6" : "w-8 h-8"} />
                  </div>
                </div>
                {ititle && (
                  <div class="ml-6">
                    <h3 class="text-xl font-bold mb-1">{ititle}</h3>
                    <p class="text-lg text-muted dark:text-slate-400 leading-relaxed">{description}</p>
                  </div>
                )}
              </div>
            ))}
          </div>
        )}

        {callToAction && callToAction.text && (
          <div class="w-fit">
            <Button {...callToAction} class="shadow-lg px-8 py-3" />
          </div>
        )}
      </div>
      
      <!-- Image Container (Below Text on Mobile) -->
      <div class="flex items-center md:basis-1/2 w-full mt-10 md:mt-0">
        {image && (
          
          <div class="relative m-auto max-w-5xl w-full aspect-[3/2] overflow-hidden rounded-lg shadow-2xl border-4 border-white dark:border-slate-800 group">
            <!-- HANEI WATERMARK OVERLAY -->
            <div class="absolute bottom-[8%] right-[5%] z-20 w-[15%] max-w-[80px] opacity-90 pointer-events-none drop-shadow-md">
              <img src="/images/logo_main.png" alt="English Support" class="w-full h-auto rounded-md" />
            </div>

            <div class="w-full h-full [&_img]:w-full [&_img]:h-full [&_img]:object-cover [&_img]:aspect-[3/2]">
              {typeof image === 'string' ? (
                <img src={image} class="w-full h-full object-cover" loading="lazy" />
              ) : image.src ? (
                <img src={image.src} alt={image.alt || ''} class="w-full h-full object-cover" loading="lazy" />
              ) : (
                <Fragment set:html={image} />
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
