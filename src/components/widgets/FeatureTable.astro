---
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

const { title, subtitle, items = [], footerText = 'Delivered within 1 business day' } = Astro.props;
---

<section class="py-12 md:py-20 bg-slate-50 dark:bg-slate-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-3xl mb-12 mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold font-heading mb-4 text-gray-900 dark:text-white">{title}</h2>
      <p class="text-xl text-muted dark:text-slate-400">{subtitle}</p>
    </div>

    <div class="max-w-5xl mx-auto bg-white dark:bg-slate-900 rounded-xl shadow-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
      <!-- Header Row -->
      <div class="bg-slate-50 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
        <div class="p-4 font-bold uppercase tracking-wider text-xs text-slate-500 dark:text-slate-400 text-center">Grand Reform & Grand NEW Services features included</div>
      </div>

      <!-- Feature Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2">
        {items.map((item) => (
          <div class="flex items-center justify-between p-5 border-b border-slate-100 dark:border-slate-800 md:odd:border-r">
            <span class="text-base font-semibold text-slate-700 dark:text-slate-200">{item.title}</span>
            <div class="flex-shrink-0 bg-green-500 rounded-md p-1 shadow-sm ml-4">
              <Icon name="tabler:check" class="w-5 h-5 text-white stroke-[4px]" />
            </div>
          </div>
        ))}
      </div>
      
      <!-- Footer Note -->
      <div class="p-4 bg-slate-50 dark:bg-slate-800/50 text-center border-t border-slate-200 dark:border-slate-700">
         <span class="text-sm font-bold text-primary uppercase tracking-widest italic">{footerText}</span>
      </div>
    </div>
  </div>
</section>
